{
  "name": "resonate",
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "description": "Open, community-owned loudspeaker enclosure simulator that runs in any browser.",
  "license": "MIT",
  "scripts": {
    "lint": "eslint packages/",
    "check": "npm run lint && npm run test:unit",
    "ci": "npm run lint && npm run test",
    "predev": "node scripts/bundle-drivers.mjs && npm run lint",
    "dev": "vite",
    "prebuild": "node scripts/bundle-drivers.mjs && npm run lint",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:unit && node packages/engine/test/golden.test.mjs && npx playwright test",
    "test:unit": "node --test packages/engine/test/*.test.mjs packages/ui/test/config.test.mjs",
    "test:crosscheck": "npx playwright test packages/ui/test/micka-crosscheck.browser.spec.js --timeout=60000",
    "test:visual": "npx playwright test packages/ui/test/visual.browser.spec.js",
    "gen-scenarios": "node packages/ui/test/gen-scenarios.mjs",
    "gen-golden": "node packages/engine/test/gen-golden.mjs"
  },
  "keywords": [
    "loudspeaker",
    "speaker",
    "enclosure",
    "thiele-small",
    "winisd",
    "acoustics",
    "diyaudio",
    "simulator"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^10.6.0",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0"
  },
  "dependencies": {
    "@resonate/engine": "*",
    "vue": "^3.5.38"
  }
}
